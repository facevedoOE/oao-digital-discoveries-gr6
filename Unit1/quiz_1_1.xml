<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2
                 http://www.imsglobal.org/xsd/ims_qtiasiv1p2p1.xsd">

  <assessment ident="quiz_lesson_1_1" title="Lesson 1.1 Knowledge Check – What Is Digital Communication?">
    <qtimetadata>
      <qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
      <qtimetadatafield><fieldlabel>cc_show_solution</fieldlabel><fieldentry>true</fieldentry></qtimetadatafield>
    </qtimetadata>

    <section ident="section_1_1" title="Questions">

      <!-- ══ Q1 ══════════════════════════════════════════════ -->
      <item ident="q1_1_1" title="Question 1">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html"><![CDATA[
            <p>Which of the following is the <strong>BEST</strong> example of <strong>synchronous</strong> digital communication?</p>
          ]]></mattext></material>
          <response_lid ident="resp_q1_1_1" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext texttype="text/plain">Posting a reply to a discussion board the night before class</mattext></material></response_label>
              <response_label ident="b"><material><mattext texttype="text/plain">Sending an email to your teacher asking about homework</mattext></material></response_label>
              <response_label ident="c"><material><mattext texttype="text/plain">Joining a live video call with your classmates to work on a project</mattext></material></response_label>
              <response_label ident="d"><material><mattext texttype="text/plain">Leaving a voice message for a friend</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="resp_q1_1_1">c</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="correct_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="incorrect_fb_q1"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="correct_fb">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>✅ <strong>Correct!</strong> Live video calls happen in real time with all participants present — that is the definition of synchronous communication. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
        <itemfeedback ident="incorrect_fb_q1">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>❌ <strong>Not quite.</strong> The correct answer is <strong>C</strong>. Synchronous communication requires both parties to be online at the same time — like a live video call. Emails, discussion posts, and voice messages are all asynchronous because they can be read or heard later. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
      </item>

      <!-- ══ Q2 ══════════════════════════════════════════════ -->
      <item ident="q1_1_2" title="Question 2">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html"><![CDATA[
            <p>What is a <strong>data packet</strong>?</p>
          ]]></mattext></material>
          <response_lid ident="resp_q1_1_2" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext texttype="text/plain">A folder that stores all of your digital files</mattext></material></response_label>
              <response_label ident="b"><material><mattext texttype="text/plain">A password that protects your messages</mattext></material></response_label>
              <response_label ident="c"><material><mattext texttype="text/plain">A small chunk of information that travels across a network</mattext></material></response_label>
              <response_label ident="d"><material><mattext texttype="text/plain">A type of router used to connect devices</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="resp_q1_1_2">c</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="correct_fb_q2"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="incorrect_fb_q2"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="correct_fb_q2">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>✅ <strong>Correct!</strong> Data packets are small chunks of a message that travel across a network and are reassembled at the destination. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
        <itemfeedback ident="incorrect_fb_q2">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>❌ <strong>Not quite.</strong> The correct answer is <strong>C</strong>. When you send a message, it is broken into small pieces called data packets that travel separately across the network and are reassembled at the other end. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
      </item>

      <!-- ══ Q3 ══════════════════════════════════════════════ -->
      <item ident="q1_1_3" title="Question 3">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html"><![CDATA[
            <p>You need to send a detailed question to your science teacher about an upcoming project. Which tool is <strong>MOST</strong> appropriate?</p>
          ]]></mattext></material>
          <response_lid ident="resp_q1_1_3" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext texttype="text/plain">A quick text message with abbreviations</mattext></material></response_label>
              <response_label ident="b"><material><mattext texttype="text/plain">An email written in a clear, polite tone</mattext></material></response_label>
              <response_label ident="c"><material><mattext texttype="text/plain">A reaction emoji on a class post</mattext></material></response_label>
              <response_label ident="d"><material><mattext texttype="text/plain">A live video call at midnight</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="resp_q1_1_3">b</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="correct_fb_q3"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="incorrect_fb_q3"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="correct_fb_q3">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>✅ <strong>Correct!</strong> Email is the most appropriate tool for a formal, detailed question to a teacher — it allows you to write a complete, polite message. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
        <itemfeedback ident="incorrect_fb_q3">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>❌ <strong>Not quite.</strong> The correct answer is <strong>B</strong>. Email is the best tool for a detailed, formal question to a teacher because it is professional, asynchronous (no need to both be online at the same time), and allows a complete, thoughtful message. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
      </item>

      <!-- ══ Q4 ══════════════════════════════════════════════ -->
      <item ident="q1_1_4" title="Question 4">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html"><![CDATA[
            <p>Which statement <strong>BEST</strong> describes <strong>asynchronous</strong> communication?</p>
          ]]></mattext></material>
          <response_lid ident="resp_q1_1_4" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext texttype="text/plain">Both people must be online at the same time to communicate.</mattext></material></response_label>
              <response_label ident="b"><material><mattext texttype="text/plain">Messages are sent and received at different times, not in real time.</mattext></material></response_label>
              <response_label ident="c"><material><mattext texttype="text/plain">Asynchronous communication only works for video calls.</mattext></material></response_label>
              <response_label ident="d"><material><mattext texttype="text/plain">Asynchronous communication requires a special network.</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="resp_q1_1_4">b</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="correct_fb_q4"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="incorrect_fb_q4"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="correct_fb_q4">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>✅ <strong>Correct!</strong> Asynchronous communication does not require both parties to be online at the same time — messages are sent and read on the receiver's own schedule. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
        <itemfeedback ident="incorrect_fb_q4">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>❌ <strong>Not quite.</strong> The correct answer is <strong>B</strong>. The prefix "a-" means "not" — so asynchronous means NOT at the same time. Emails and discussion posts are classic examples: you send when you are ready, and they read when they are ready. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
      </item>

      <!-- ══ Q5 ══════════════════════════════════════════════ -->
      <item ident="q1_1_5" title="Question 5">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html"><![CDATA[
            <p>In digital communication, what is the role of a <strong>router</strong>?</p>
          ]]></mattext></material>
          <response_lid ident="resp_q1_1_5" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext texttype="text/plain">It creates new messages on behalf of the sender.</mattext></material></response_label>
              <response_label ident="b"><material><mattext texttype="text/plain">It stores all data packets permanently on a server.</mattext></material></response_label>
              <response_label ident="c"><material><mattext texttype="text/plain">It directs data packets to the correct destination across a network.</mattext></material></response_label>
              <response_label ident="d"><material><mattext texttype="text/plain">It converts text messages into voice messages.</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="resp_q1_1_5">c</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="correct_fb_q5"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar><other/></conditionvar>
            <setvar action="Set" varname="SCORE">0</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="incorrect_fb_q5"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="correct_fb_q5">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>✅ <strong>Correct!</strong> Routers direct data packets along the best route to reach their destination — like digital traffic directors. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
        <itemfeedback ident="incorrect_fb_q5">
          <flow_mat><material><mattext texttype="text/html"><![CDATA[<p>❌ <strong>Not quite.</strong> The correct answer is <strong>C</strong>. A router is a device that reads where each data packet needs to go and sends it along the fastest available path — like a traffic director at a busy intersection. (SC.6.CC.1.1)</p>]]></mattext></material></flow_mat>
        </itemfeedback>
      </item>

    </section>
  </assessment>
</questestinterop>
